<Page
    x:Class="test.UWP.MyContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel
            HorizontalAlignment="Center"
            Spacing="20"
            Padding="30"
            Width="700">

            <TextBlock
                Text="Media &amp; Document Player"
                FontSize="28"
                FontWeight="SemiBold"
                HorizontalAlignment="Center"
                Margin="0,0,0,10"/>

            <TextBlock
                Text="Select a video, music, or text file to play or read"
                FontSize="14"
                Foreground="Gray"
                HorizontalAlignment="Center"
                Margin="0,0,0,20"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
                <Button x:Name="SelectVideoButton" Content="Select Video" Click="SelectVideoButton_Click" Width="150" Padding="10,6"/>
                <Button x:Name="SelectMusicButton" Content="Select Music" Click="SelectMusicButton_Click" Width="150" Padding="10,6"/>
                <Button x:Name="SelectTextButton" Content="Select Text File" Click="SelectTextButton_Click" Width="150" Padding="10,6"/>
            </StackPanel>

            <!-- Video Player -->
            <TextBlock Text="Video Player" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,30,0,5"/>
            <MediaPlayerElement x:Name="VideoPlayer" Width="640" Height="360" AreTransportControlsEnabled="True" Visibility="Collapsed" HorizontalAlignment="Center"/>
            <Button x:Name="CloseVideoButton" Content="Close" Click="CloseVideoButton_Click" Width="100" Visibility="Collapsed" HorizontalAlignment="Center"/>

            <!-- Music Player -->
            <TextBlock Text="Music Player" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,30,0,5"/>
            <MediaPlayerElement x:Name="MusicPlayer" Width="400" Height="80" AreTransportControlsEnabled="True" Visibility="Collapsed" HorizontalAlignment="Center"/>
            <Button x:Name="CloseMusicButton" Content="Close" Click="CloseMusicButton_Click" Width="100" Visibility="Collapsed" HorizontalAlignment="Center"/>

            <!-- Text Viewer -->
            <TextBlock Text="Text File Viewer" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,30,0,5"/>
            <Border
                x:Name="TextScrollViewer"
                Width="640"
                Height="240"
                Background="White"
                BorderBrush="{ThemeResource SystemControlHighlightAccentBrush}"
                BorderThickness="2"
                Visibility="Collapsed"
                HorizontalAlignment="Center"
                Padding="8">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="Transparent">
                    <TextBlock x:Name="TextViewer" TextWrapping="Wrap" FontSize="16" IsTextSelectionEnabled="True" Foreground="Black"/>
                </ScrollViewer>
            </Border>
            <Button x:Name="CloseTextButton" Content="Close" Click="CloseTextButton_Click" Width="100" Visibility="Collapsed" HorizontalAlignment="Center"/>
        </StackPanel>
    </ScrollViewer>
</Page>
