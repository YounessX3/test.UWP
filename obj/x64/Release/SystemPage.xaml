<Page
    x:Class="test.UWP.SystemPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="20" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">

            <!-- Title -->
            <TextBlock Text="System Settings" FontSize="30" Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}" Margin="0,0,0,20"/>

            <!-- Buttons -->
            <Button Content="Click me" Margin="0,0,0,10"/>
            <Button Content="I do nothing" Margin="0,0,0,10"/>

            <!-- Resolution Section -->
            <TextBlock Text="Display Resolution" FontSize="18" Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}" Margin="0,20,0,10"/>
            <ComboBox x:ConnectionId='2' x:Name="ResolutionComboBox" SelectedIndex="0"                                                        Margin="0,0,0,10">
                <ComboBoxItem Content="1920 x 1080"/>
                <ComboBoxItem Content="1600 x 900"/>
                <ComboBoxItem Content="1366 x 768"/>
                <ComboBoxItem Content="1280 x 720"/>
            </ComboBox>

            <!-- Volume Control -->
            <TextBlock Text="Volume Control" FontSize="18" Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}" Margin="0,20,0,10"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                <Slider x:ConnectionId='9' x:Name="VolumeSlider" Minimum="0" Maximum="100" Value="50" Width="200"                                         />
                <TextBlock x:ConnectionId='10' x:Name="VolumeValueText" Text="50" Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}" FontSize="18" Margin="15,0,0,0" VerticalAlignment="Center" Width="30" TextAlignment="Right"/>
            </StackPanel>
            <ToggleSwitch Header="Mute" Margin="0,0,0,10"/>

            <!-- Dropdown Example -->
            <TextBlock Text="Theme Selection" FontSize="18" Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}" Margin="0,20,0,10"/>
            <ComboBox Margin="0,0,0,10" SelectedIndex="0">
                <ComboBoxItem Content="Light"/>
                <ComboBoxItem Content="Dark"/>
                <ComboBoxItem Content="System Default"/>
            </ComboBox>

            <!-- Text Input -->
            <TextBlock Text="Username" FontSize="18" Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}" Margin="0,20,0,10"/>
            <TextBox PlaceholderText="Enter your username" Margin="0,0,0,10"/>

            <!-- Expander / Accordion -->
            <ToggleButton x:ConnectionId='3' x:Name="AdvancedToggle" Content="Advanced Settings" IsTabStop="True"
                          Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}" FontSize="18" FontWeight="SemiBold" Margin="0,20,0,10"/>
            <StackPanel x:ConnectionId='4' x:Name="AdvancedContent" Spacing="10" Padding="10" Visibility="Collapsed">
                <TextBlock Text="Enable Developer Mode" Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                <ToggleSwitch x:ConnectionId='5' x:Name="DeveloperModeToggle" Margin="0,0,0,10"/>

                <TextBlock Text="Logging Level" Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                <ComboBox x:ConnectionId='6' x:Name="LoggingLevelComboBox" SelectedIndex="1">
                    <ComboBoxItem Content="Error"/>
                    <ComboBoxItem Content="Warning"/>
                    <ComboBoxItem Content="Info"/>
                    <ComboBoxItem Content="Debug"/>
                </ComboBox>

                <TextBlock Text="API Endpoint" Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}" Margin="0,10,0,0"/>
                <TextBox x:ConnectionId='7' x:Name="ApiEndpointTextBox" PlaceholderText="https://api.example.com" Margin="0,0,0,10" IsTabStop="True" />

                <Button x:ConnectionId='8' Content="Reset Advanced Settings" HorizontalAlignment="Left"                                    />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>

