<Page
    x:Class="test.UWP.UpdateSecurityPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:test.UWP"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="36">
        <StackPanel Spacing="36">

            <!-- Title -->
            <TextBlock Text="Windows Update"
                       FontSize="36"
                       FontWeight="SemiBold" />

            <!-- Steps Progress Bar -->
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE73E;" FontSize="18" Foreground="Green"/>
                <Rectangle Height="2" Width="32" Fill="Gray" VerticalAlignment="Center"/>
                <FontIcon Glyph="&#xE9EA;" FontSize="18" Foreground="Gray"/>
                <Rectangle Height="2" Width="32" Fill="Gray" VerticalAlignment="Center"/>
                <FontIcon Glyph="&#xEBC3;" FontSize="18" Foreground="Gray"/>
                <Rectangle Height="2" Width="32" Fill="Gray" VerticalAlignment="Center"/>
                <FontIcon Glyph="&#xE896;" FontSize="18" Foreground="Gray"/>
            </StackPanel>

            <!-- Check for updates Button -->
            <Button x:ConnectionId='2' Content="Check for updates"
                    Width="220"
                    Height="48"
                                              
                    HorizontalAlignment="Left"
                    CornerRadius="0" />

            <!-- Status Text -->
            <StackPanel Spacing="4">
                <TextBlock x:ConnectionId='3' x:Name="StatusTextBlock"
                           Text="You're up to date."
                           FontSize="18"
                           FontWeight="SemiBold" />
                <TextBlock x:ConnectionId='4' x:Name="LastCheckedTextBlock"
                           Text="Last checked: Today at 06:15"
                           FontSize="14"
                           Foreground="Gray"/>
            </StackPanel>

            <!-- Optional Downloads Placeholder -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="12" CornerRadius="0" Background="#11FFFFFF">
                <StackPanel>
                    <TextBlock Text="Optional Updates Available"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Driver update for Generic Display Adapter"
                               Foreground="Gray" Margin="0,4,0,0"/>
                    <Button Content="Download and install" Width="180" Margin="0,8,0,0" CornerRadius="0"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>

