<Page
    x:Class="test.UWP.NetworkInternetPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Padding="36" Spacing="24">

            <!-- Page Title -->
            <TextBlock Text="Network &amp; Internet"
                       FontSize="32"
                       FontWeight="Bold"
                       Margin="0,0,0,6" />

            <!-- Subtitle -->
            <TextBlock Text="Wi-Fi, airplane mode, VPN"
                       FontSize="16"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />

            <!-- Wi-Fi Section -->
            <StackPanel Spacing="12">
                <TextBlock Text="Wi-Fi"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <ToggleSwitch x:ConnectionId='4' x:Name="WifiToggle"
                              Header="Wi-Fi"
                              OnContent="On"
                              OffContent="Off"
                                                           />
                <ComboBox x:ConnectionId='5' Header="Available Networks"
                          x:Name="WifiNetworksCombo"
                          PlaceholderText="Not connected"
                          Width="300">
                    <ComboBoxItem Content="Home_WiFi"/>
                    <ComboBoxItem Content="Guest_Network"/>
                    <ComboBoxItem Content="Public_Hotspot"/>
                </ComboBox>
                <Button x:ConnectionId='6' Content="Connect"
                                                 
                        HorizontalAlignment="Left"/>
            </StackPanel>

            <!-- Airplane Mode -->
            <StackPanel Spacing="12">
                <TextBlock Text="Airplane Mode"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,30,0,0" />
                <ToggleSwitch x:ConnectionId='3' Header="Airplane Mode"
                              x:Name="AirplaneToggle"
                              OnContent="On"
                              OffContent="Off"
                                                               />
            </StackPanel>

            <!-- VPN Section -->
            <StackPanel Spacing="12">
                <TextBlock Text="VPN"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,30,0,0" />
                <TextBox PlaceholderText="Enter VPN address..." Width="300"/>
                <Button x:ConnectionId='2' Content="Connect to VPN"
                                                
                        HorizontalAlignment="Left" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>

