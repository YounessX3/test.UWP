<Page
    x:Class="test.UWP.TimeLanguagePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:test.UWP"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="36">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="Time &amp; Language"
                   FontSize="36"
                   FontWeight="SemiBold"
                   Margin="0,0,0,24"/>

        <!-- Content -->
        <StackPanel Grid.Row="1" Spacing="36" HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- Big digital clock -->
            <TextBlock x:ConnectionId='2' x:Name="ClockText"
                       FontSize="72"
                       FontWeight="Bold"
                       Text="00:00:00"
                       HorizontalAlignment="Center"/>

            <!-- Region and language info -->
            <StackPanel Orientation="Vertical" Spacing="12" HorizontalAlignment="Center">
                <TextBlock x:ConnectionId='3' x:Name="RegionText"
                           FontSize="20"
                           FontWeight="SemiBold"/>
                <TextBlock x:ConnectionId='4' x:Name="LanguageText"
                           FontSize="20"
                           FontWeight="SemiBold"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>

