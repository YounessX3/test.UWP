<Page
    x:Class="test.UWP.DevicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Padding="36" Spacing="20">

            <!-- Page Title -->
            <TextBlock Text="Devices"
                       FontSize="32"
                       FontWeight="Bold"
                       Margin="0,0,0,10" />

            <!-- Description -->
            <TextBlock Text="Manage your Bluetooth devices, printers, and peripherals."
                       FontSize="16"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />

            <!-- Section 1: Bluetooth -->
            <StackPanel Spacing="10">
                <TextBlock Text="Bluetooth"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <ToggleSwitch x:ConnectionId='3' Header="Bluetooth"
                              OffContent="Off"
                              OnContent="On"
                              x:Name="BluetoothToggle"
                                                                />
            </StackPanel>

            <!-- Section 2: Printers -->
            <StackPanel Spacing="10" Margin="0,20,0,0">
                <TextBlock Text="Printers &amp; Scanners"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <Button x:ConnectionId='2' Content="Add a Printer or Scanner"
                                                      
                        HorizontalAlignment="Left" />
            </StackPanel>

            <!-- Section 3: Mouse -->
            <StackPanel Spacing="10" Margin="0,20,0,0">
                <TextBlock Text="Mouse"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <Slider Minimum="1" Maximum="10" Value="5" Header="Pointer Speed" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>

