<Page
    x:Class="test.UWP.GamingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:test.UWP"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="36">
        <StackPanel Spacing="36">

            <TextBlock Text="Gaming"
                       FontSize="36"
                       FontWeight="SemiBold" />

            <!-- Game Bar Toggle -->
            <StackPanel>
                <TextBlock Text="Xbox Game Bar" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ToggleSwitch x:ConnectionId='2' x:Name="GameBarToggle"
                              Header="Enable Xbox Game Bar for things like recording clips, chatting with friends, and receiving game invites."
                              IsOn="True"/>
            </StackPanel>

            <!-- Capture settings -->
            <StackPanel>
                <TextBlock Text="Captures" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Text="Capture location: This PC > Videos > Captures" Foreground="Gray" />
                <Slider Header="Recorded video quality"
                        Minimum="1" Maximum="100" Value="75" />
                <CheckBox Content="Record audio when I record a game" IsChecked="True"/>
            </StackPanel>

            <!-- Streaming settings -->
            <StackPanel>
                <TextBlock Text="Streaming" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Text="Tweak your stream appearance and quality." Foreground="Gray"/>
                <ComboBox Header="Stream Quality" SelectedIndex="1">
                    <ComboBoxItem>Low</ComboBoxItem>
                    <ComboBoxItem>Medium</ComboBoxItem>
                    <ComboBoxItem>High</ComboBoxItem>
                </ComboBox>
                <CheckBox Content="Enable microphone while streaming" IsChecked="False"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>

