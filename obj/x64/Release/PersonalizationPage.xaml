<Page
    x:Class="test.UWP.PersonalizationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:test.UWP"
    xmlns:media="using:Windows.UI"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Padding="36" Spacing="24">

            <!-- Page Title -->
            <TextBlock Text="Personalization"
                       FontSize="32"
                       FontWeight="Bold"
                       Margin="0,0,0,6"/>

            <TextBlock Text="Background, colors, theme"
                       FontSize="16"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />

            <!-- Background Selection -->
            <StackPanel Spacing="12">
                <TextBlock Text="Background"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <ComboBox x:ConnectionId='4' x:Name="BackgroundCombo"
                          Header="Choose background"
                          Width="300"
                                                                             >
                    <ComboBoxItem Content="Windows Spotlight"/>
                    <ComboBoxItem Content="Picture"/>
                    <ComboBoxItem Content="Solid color"/>
                    <ComboBoxItem Content="Slideshow"/>
                </ComboBox>
                <Image x:ConnectionId='5' x:Name="PreviewImage"
                       Width="300" Height="160"
                       Stretch="UniformToFill"
                       Margin="0,10,0,0"
                       Source="ms-appx:///Assets/PreviewBackground.jpg"/>
            </StackPanel>

            <!-- Theme Selection -->
            <StackPanel Spacing="12" Margin="0,30,0,0">
                <TextBlock Text="Theme"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <ToggleSwitch x:ConnectionId='3' x:Name="ThemeToggle"
                              Header="Dark Mode"
                              OnContent="Dark"
                              OffContent="Light"
                                                           />
            </StackPanel>

            <!-- Accent Color -->
            <StackPanel Spacing="12" Margin="0,30,0,0">
                <TextBlock Text="Accent Color"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <ColorPicker x:ConnectionId='2' x:Name="AccentColorPicker"
                                                                          
                             Width="300" Height="300"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>

