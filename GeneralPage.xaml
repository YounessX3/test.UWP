<Page
    x:Class="test.UWP.GeneralPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#121212">

    <ScrollViewer Padding="20" Background="Black" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">

            <!-- Title -->
            <TextBlock Text="Welcome to General Settings" FontSize="30" Foreground="White" Margin="0,0,0,20"/>

            <!-- Buttons -->
            <Button Content="Click me" Margin="0,0,0,10"/>
            <Button Content="I do nothing" Margin="0,0,0,10"/>

            <!-- Resolution Section -->
            <TextBlock Text="Display Resolution" FontSize="18" Foreground="White" Margin="0,20,0,10"/>
            <Button x:Name="ResolutionButton"
                    Click="ResolutionButton_Click"
                    IsTabStop="True"
                    Content="{Binding SelectedResolution, Mode=OneWay}"
                    Margin="0,0,0,10">
                <Button.Flyout>
                    <Flyout Placement="Bottom">
                        <ListView x:Name="ResolutionList"
                                  SelectionChanged="ResolutionList_SelectionChanged"
                                  Width="200">
                            <ListViewItem Content="1920 x 1080"/>
                            <ListViewItem Content="1600 x 900"/>
                            <ListViewItem Content="1366 x 768"/>
                            <ListViewItem Content="1280 x 720"/>
                        </ListView>
                    </Flyout>
                </Button.Flyout>
            </Button>

            <!-- Volume Control -->
            <TextBlock Text="Volume Control" FontSize="18" Foreground="White" Margin="0,20,0,10"/>
            <Slider Minimum="0" Maximum="100" Value="50" TickFrequency="10" TickPlacement="BottomRight" Margin="0,0,0,10"/>
            <ToggleSwitch Header="Mute" Margin="0,0,0,10"/>

            <!-- Dropdown Example -->
            <TextBlock Text="Theme Selection" FontSize="18" Foreground="White" Margin="0,20,0,10"/>
            <ComboBox Margin="0,0,0,10" SelectedIndex="0">
                <ComboBoxItem Content="Light"/>
                <ComboBoxItem Content="Dark"/>
                <ComboBoxItem Content="System Default"/>
            </ComboBox>

            <!-- Text Input -->
            <TextBlock Text="Username" FontSize="18" Foreground="White" Margin="0,20,0,10"/>
            <TextBox PlaceholderText="Enter your username" Margin="0,0,0,10"/>

            <!-- Expander / Accordion -->
            <!-- Instead of Expander -->
            <ToggleButton x:Name="AdvancedToggle" Content="Advanced Settings"  IsTabStop="True"
              Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,20,0,10"/>
            <StackPanel x:Name="AdvancedContent" Spacing="10" Padding="10" Visibility="Collapsed">
                <TextBlock Text="Enable Developer Mode" Foreground="White"/>
                <ToggleSwitch x:Name="DeveloperModeToggle" Margin="0,0,0,10"/>

                <TextBlock Text="Logging Level" Foreground="White"/>
                <ComboBox x:Name="LoggingLevelComboBox" SelectedIndex="1">
                    <ComboBoxItem Content="Error"/>
                    <ComboBoxItem Content="Warning"/>
                    <ComboBoxItem Content="Info"/>
                    <ComboBoxItem Content="Debug"/>
                </ComboBox>

                <TextBlock Text="API Endpoint" Foreground="White" Margin="0,10,0,0"/>
                <TextBox x:Name="ApiEndpointTextBox" PlaceholderText="https://api.example.com" Margin="0,0,0,10" IsTabStop="True" />

                <Button Content="Reset Advanced Settings" HorizontalAlignment="Left" Click="ResetAdvancedSettings_Click"/>
            </StackPanel>



        </StackPanel>
    </ScrollViewer>
</Page>
