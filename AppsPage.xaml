<Page
    x:Class="test.UWP.AppsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:test.UWP"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="12">
        <TextBlock Text="Apps &amp; Tools" FontSize="36" FontWeight="SemiBold" Margin="0,0,0,24"/>

        <ListView x:Name="AppsListView" Margin="0,60,0,0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="16" Padding="12">
                        <FontIcon Glyph="{Binding Icon}" FontSize="36" VerticalAlignment="Center" />
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="18" />
                            <TextBlock Text="{Binding Description}" FontSize="14" Foreground="Gray" />
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
