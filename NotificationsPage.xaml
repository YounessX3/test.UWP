<Page
    x:Class="test.UWP.NotificationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#121212">

    <ScrollViewer Padding="20" Background="Black">
        <StackPanel Spacing="12">
            <TextBlock Text="Notifications" FontSize="30" Foreground="White" Margin="0,0,0,20"/>
            <TextBlock Text="Customize notification settings." Foreground="LightGray" Margin="0,0,0,20"/>

            <!-- Native Fluent-style dropdown selector like Settings -->
            <TextBlock Text="Notification Style" Foreground="White" Margin="0,0,0,4"/>
            <ComboBox x:Name="NotificationStyleComboBox"
                      Width="250"
                      SelectionChanged="NotificationStyleComboBox_SelectionChanged">
                <ComboBoxItem Content="Banner and Sound" IsSelected="True"/>
                <ComboBoxItem Content="Only Banner"/>
                <ComboBoxItem Content="Only Sound"/>
                <ComboBoxItem Content="Silent"/>
            </ComboBox>

            <!-- Other toggle-style settings -->
            <ToggleSwitch Header="Enable Toasts" Margin="0,20,0,0"/>
            <ToggleSwitch Header="Quiet Hours"/>
            <ToggleSwitch Header="Notification Sounds"/>
        </StackPanel>
    </ScrollViewer>
</Page>
